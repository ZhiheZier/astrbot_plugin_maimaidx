{
  "bot_name": {
    "description": "机器人名称",
    "hint": "用于在消息中显示（如：今日运势功能）",
    "type": "string",
    "default": "Bot"
  },
  "enable_reply": {
    "description": "引用回复",
    "hint": "是否在多数指令回复中添加“引用消息”（Reply）。关闭可减少引用/提及效果。",
    "type": "bool",
    "default": true
  },
  "maimaidxtoken": {
    "description": "查分器开发者 Token",
    "hint": "用于访问查分器接口",
    "type": "string",
    "default": ""
  },
  "maimaidxaliaswhitelist": {
    "description": "别名推送白名单",
    "hint": "开启后仅向已执行「开启别名推送」的群发送别名广播；关闭则保持原逻辑（全群推送，排除黑名单）。",
    "type": "bool",
    "default": false
  }
}

